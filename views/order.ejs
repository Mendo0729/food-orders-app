<%- include('partials/header') %>

<main class="marketplace-page">
  <section class="marketplace-hero py-5">
    <div class="container">
      <div class="row align-items-end g-4">
        <div class="col-lg-8">
          <p class="eyebrow gold pattern-title mb-3">Iglesia Episcopal de Cristo a la Orilla del Mar</p>
          <h1 class="display-title compact mb-3">Comida afroantillana</h1>
          <p class="hero-subtitle mb-0">Selecciona el Menu Principal Afroantillano y agrega los productos especiales que deseas reservar.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="marketplace-shell py-5">
    <div class="container">
      <% if (success) { %>
        <div class="alert alert-success">Pedido registrado correctamente. Gracias por apoyar la actividad.</div>
      <% } %>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form id="orderForm" action="/pedidos" method="POST" class="order-form">
        <div class="row g-4 align-items-start">
          <div class="col-lg-8">
            <div class="section-heading text-center mb-4">
              <p class="eyebrow gold">Menu disponible</p>
              <h2>Sabores de nuestra comunidad</h2>
            </div>

            <div class="menu-sections">
              <% dishGroups.forEach((group) => { %>
                <section class="menu-section">
                  <div class="menu-section-heading">
                    <h3><%= group.label %></h3>
                  </div>

                  <div class="menu-items-grid">
                    <% group.dishes.forEach((dish) => { %>
                      <%
                        const hasQuantity = Object.prototype.hasOwnProperty.call(quantities, dish.id);
                        const rawQuantityValue = hasQuantity ? Number(quantities[dish.id]) : (dish.is_main_menu ? 1 : 0);
                        const quantityValue = dish.is_main_menu ? Math.max(1, rawQuantityValue || 0) : rawQuantityValue;
                      %>
                      <article class="order-dish <%= dish.is_main_menu ? 'main-menu-dish' : '' %>">
                        <div class="order-dish-content">
                          <div>
                            <h4><%= dish.name %></h4>
                            <% if (dish.description) { %>
                              <p><%= dish.description %></p>
                            <% } %>
                          </div>

                          <div class="order-dish-price">
                            <% if (dish.price === null) { %>
                              <span>Consultar</span>
                            <% } else { %>
                              <strong>$<%= Number(dish.price).toFixed(2) %></strong>
                            <% } %>
                          </div>
                        </div>

                        <div class="order-dish-actions">
                          <% if (dish.category === 'Adicional') { %>
                            <label class="form-check add-on-check" for="enable_<%= dish.id %>">
                              <input class="form-check-input addon-toggle" type="checkbox" id="enable_<%= dish.id %>" data-target="quantity_<%= dish.id %>" <%= Number(quantities[dish.id] || 0) > 0 ? 'checked' : '' %>>
                              <span>Agregar</span>
                            </label>
                          <% } %>

                          <label for="quantity_<%= dish.id %>" class="quantity-label">Cantidad</label>
                          <div class="quantity-pill" data-min="<%= dish.is_main_menu ? 1 : 0 %>">
                            <button type="button" class="quantity-step" data-step="-1" aria-label="Reducir cantidad">-</button>
                            <input
                              type="number"
                              min="<%= dish.is_main_menu ? 1 : 0 %>"
                              step="1"
                              class="marketplace-quantity priced-quantity <%= dish.is_main_menu ? 'main-menu-quantity' : '' %>"
                              id="quantity_<%= dish.id %>"
                              name="quantities[<%= dish.id %>]"
                              value="<%= quantityValue %>"
                              data-price="<%= dish.price === null ? '' : Number(dish.price) %>"
                              data-min="<%= dish.is_main_menu ? 1 : 0 %>"
                              data-dish-name="<%= dish.name %>"
                              aria-label="Cantidad de <%= dish.name %>"
                            >
                            <button type="button" class="quantity-step" data-step="1" aria-label="Aumentar cantidad">+</button>
                          </div>
                        </div>
                      </article>
                    <% }) %>
                  </div>
                </section>
              <% }) %>
            </div>
          </div>

          <aside class="col-lg-4">
            <div class="cart-panel order-summary-panel">
              <p class="eyebrow gold mb-1">Datos del pedido</p>
              <h2 class="h4 fw-bold mb-3">Reserva</h2>

              <div class="mb-3">
                <label for="customer_name" class="form-label">Nombre del cliente</label>
                <input type="text" class="form-control" id="customer_name" name="customer_name" value="<%= formData.customer_name || '' %>" required>
              </div>

              <div class="mb-3">
                <label for="phone" class="form-label">Numero celular</label>
                <input type="tel" class="form-control" id="phone" name="phone" value="<%= formData.phone || '' %>" required>
              </div>

              <div class="order-estimate">
                <div class="cart-total">
                  <span>Total estimado</span>
                  <strong id="orderTotal">$0.00</strong>
                </div>
                <p class="summary-note mb-0">Los productos marcados como Consultar se confirman al coordinar el pedido.</p>
              </div>

              <button type="submit" class="btn btn-gold w-100 mt-3">Confirmar pedido</button>
            </div>
          </aside>
        </div>
      </form>
    </div>
  </section>
</main>

<div class="modal fade order-status-modal" id="orderStatusModal" tabindex="-1" aria-labelledby="orderStatusTitle" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body text-center">
        <div class="order-status-icon" id="orderStatusIcon">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
        </div>
        <h2 class="h4 fw-bold mt-3" id="orderStatusTitle">Guardando pedido</h2>
        <p class="mb-0" id="orderStatusMessage">Por favor espera mientras confirmamos tu pedido.</p>
        <button type="button" class="btn btn-gold w-100 mt-4 d-none" id="orderStatusClose" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
